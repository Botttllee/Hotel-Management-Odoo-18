<odoo>
  <data>
    <record id="view_res_config_settings_hotelv18" model="ir.ui.view">
      <field name="name">res.config.settings.hotelv18</field>
      <field name="model">res.config.settings</field>
      <field name="inherit_id" eval="False"/>
      <field name="arch" type="xml">
        <form string="Hotel Report Settings" create="false" edit="true">
          <sheet>
            <group string="Reporting Settings">
              <field name="hotel_report_theme"/>
              <field name="hotel_report_layout"/>
              <field name="hotel_report_show_guest_phone"/>
              <field name="hotel_report_show_financial"/>
              <field name="hotel_report_footer_note" placeholder="Thank you for staying with us..." maxlength="255"/>
            </group>
            <group string="Theme Preview">
              <div class="alert alert-info">
                Preview ini untuk representasi tema pada PDF report.
              </div>
              <div invisible="hotel_report_theme != 'classic'" style="border:1px solid #cbd5e1;border-left:6px solid #1d4ed8;padding:12px;border-radius:6px;background:#f8fafc;">
                <h4 style="margin:0;color:#1d4ed8;">Classic Blue</h4>
                <p style="margin:6px 0 0 0;">Heading biru, tabel netral, cocok untuk tampilan formal.</p>
              </div>
              <div invisible="hotel_report_theme != 'forest'" style="border:1px solid #bbf7d0;border-left:6px solid #15803d;padding:12px;border-radius:6px;background:#f0fdf4;">
                <h4 style="margin:0;color:#15803d;">Forest Green</h4>
                <p style="margin:6px 0 0 0;">Nuansa hijau natural, clean, dan lembut di PDF.</p>
              </div>
              <div invisible="hotel_report_theme != 'sunset'" style="border:1px solid #fed7aa;border-left:6px solid #c2410c;padding:12px;border-radius:6px;background:#fff7ed;">
                <h4 style="margin:0;color:#c2410c;">Sunset Orange</h4>
                <p style="margin:6px 0 0 0;">Warna hangat untuk report yang lebih standout.</p>
              </div>
            </group>
          </sheet>
          <footer>
            <button name="execute" type="object" string="Save" class="btn-primary"/>
            <button string="Cancel" special="cancel" class="btn-secondary"/>
          </footer>
        </form>
      </field>
    </record>

    <record id="action_hotel_report_settings" model="ir.actions.act_window">
      <field name="name">Report Settings</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">res.config.settings</field>
      <field name="view_mode">form</field>
      <field name="view_id" ref="view_res_config_settings_hotelv18"/>
      <field name="target">new</field>
      <field name="context">{'module': 'hotelv18'}</field>
    </record>

    <menuitem id="menu_hotel_report_settings"
              name="Report Settings"
              parent="menu_config"
              action="action_hotel_report_settings"
              sequence="10"/>
  </data>
</odoo>
